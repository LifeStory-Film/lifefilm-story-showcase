11:["$","$1","c",{"children":[["$","main",null,{"className":"min-h-screen bg-[#0f0e0c] text-white","children":[["$","$L7",null,{}],["$","article",null,{"className":"pt-24 pb-32","children":["$","div",null,{"className":"container mx-auto px-6 max-w-4xl","children":[["$","nav",null,{"className":"text-sm text-gray-500 mb-10","aria-label":"Breadcrumb","children":[["$","$L8",null,{"href":"/","className":"hover:text-[#BFA181] transition-colors","children":"Home"}],["$","span",null,{"className":"mx-2","children":"/"}],["$","span",null,{"className":"text-white","children":"Malibu Wedding Videographer"}]]}],["$","header",null,{"className":"mb-10","children":[["$","div",null,{"className":"text-[#BFA181] text-xs tracking-widest uppercase mb-3","children":"Malibu, CA"}],["$","h1",null,{"className":"text-4xl md:text-6xl font-bold text-white font-['Playfair_Display'] leading-tight mb-4","children":"Malibu Wedding Videographer"}],["$","p",null,{"className":"text-xl text-gray-400 font-light","children":"Cinematic wedding films where the Santa Monica Mountains meet the Pacific."}]]}],["$","div",null,{"className":"relative aspect-[16/9] rounded-2xl overflow-hidden bg-[#1a1916] mb-12","children":["$","iframe",null,{"src":"https://www.youtube.com/embed/SoXEpK1tGYo?si=BGGRwNil8rAHfLIh","title":"Carrie & Grant — Malibu Wedding Film by LifeStory.Film","allow":"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share","allowFullScreen":true,"className":"absolute inset-0 w-full h-full"}]}],["$","div",null,{"className":"text-gray-400 text-sm italic mb-16 text-center","children":"Carrie & Grant — Malibu, CA"}],["$","div",null,{"className":"prose prose-invert prose-lg max-w-none mb-16 space-y-6 text-gray-300 leading-relaxed","children":[["$","p",null,{"children":"Malibu has a way of making everything feel both effortless and epic. The Pacific stretches out in every direction. The light at magic hour is unlike anywhere else in California. And whether you're getting married at Malibu Rocky Oaks, a private blufftop estate, or on a stretch of beach with nothing but ocean ahead of you — the setting does half our work."}],["$","p",null,{"children":"We've been filming weddings in Malibu for over fifteen years. We know the venues, the permit requirements, the access roads, and how the coastal wind behaves on an August afternoon. We know which angles showcase the Pacific and which corners give couples a rare moment of privacy during a day that's anything but. That local knowledge means nothing slips by us."}],["$","p",null,{"children":"Our Malibu films have a particular look: warm, unhurried, and full of space. We let the landscape breathe. We stay close during the moments that matter — your vows, your first look, the last dance — and pull back to show the scale of where you chose to start your life together. The result is a film that feels as wide open as the view from the cliffs."}],["$","p",null,{"children":"Every Malibu wedding is different — from intimate boho ceremonies of 20 guests to sprawling estate celebrations for 300. We approach each one the same way: with a full day's worth of attention, two cameras, and no agenda beyond making your film as honest and beautiful as your day actually was."}],["$","p",null,{"children":"Malibu dates book out quickly, especially for September and October when the light is at its best. If you have a date in mind, reach out early."}]]}],["$","div",null,{"className":"bg-[#1a1916] rounded-2xl p-10 border border-zinc-800 text-center","children":[["$","h2",null,{"className":"text-2xl font-bold text-white mb-3","children":"Planning a Malibu wedding?"}],["$","p",null,{"className":"text-gray-400 mb-6","children":"Tell us your date and we'll check availability. We respond within 24 hours."}],"$L15"]}]]}]}],"$L16"]}],null,"$L17"]}]
